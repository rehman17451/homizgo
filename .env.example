# ─── Firebase Admin SDK (server-side only — NEVER expose to client) ────────────
# From: Firebase Console → Project Settings → Service Accounts → Generate new private key
# Paste the entire JSON content as a single-line string (escape internal quotes)
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}

# ─── Notification Security ────────────────────────────────────────────────────
# A secret string you control — required in "x-notify-secret" header to call POST /api/notifications/send
# Generate with: openssl rand -base64 32
NOTIFY_SECRET=your_random_secret_here
